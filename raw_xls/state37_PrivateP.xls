function focusBox(arg)
{	
	
	arg.style.borderColor  = "black";
	  lField = arg; 
	 setTimeout("lField.focus()", 0); 

}
function validateAlphaSpace11(arg,arg2)
{

var textbox1 =  eval("document.forms[0]."+arg);    
var textval = textbox1.value;

var tbLen = textval.replace(/\s+/g,'').replace(/\s+$/g,'') ;
if(tbLen.length == 0)
	{
	 bootbox.alert('Blank spaces are not allowed in '+arg2, function() {
 	      
	        focusBox(document.getElementById(arg));
	        textbox1.value="";
		  });
 	   parent.parent.$('html, body').animate({scrollTop: 0}, 500, 'linear');
	
	
	return false;
	}
if(textval.charAt(0)==' '){ 
	
	 bootbox.alert('Starting blank spaces are not allowed in '+arg2, function() {
	      
	        focusBox(document.getElementById(arg));
	        textbox1.value="";
		  });
  	   parent.parent.$('html, body').animate({scrollTop: 0}, 500, 'linear');

	return false;
}

if(textval != null && textval != "")
{
	
	var iChars = "~`!#$%^&*+=-[]\\\';,/{}|\":<>?.";
	if(iChars.indexOf(textval.charAt(0))!= -1){
		
		 bootbox.alert('Starting special characters are not allowed in '+arg2, function() {
	   	      
	 	        focusBox(document.getElementById(arg));
	 	       textbox1.value="";
	 		  });
	   	   parent.parent.$('html, body').animate({scrollTop: 0}, 500, 'linear');
	   	   return;
	}
	if( textval.match(/[,.\(\)\/]{2}/i))
	{
	var fr = partial(textbox1);
	   
	 bootbox.alert("Continuous special characters are not allowed in "+arg2, function() {
	      
	        focusBox(document.getElementById(arg));
	       textbox1.value="";
		  });
	   parent.parent.$('html, body').animate({scrollTop: 0}, 500, 'linear');
	   return;
	}
	var reg=/^[a-zA-Z0-9 ]+$/;
	if(textval.search(reg)==-1)
	{
		textval.value="";
	   bootbox.alert('Only alphabets and digits are allowed in '+arg2,function(){
		   focusBox(document.getElementById(arg));
		   textbox1.value="";
	   });
	   parent.parent.$('html, body').animate({scrollTop: 0}, 500, 'linear');
       return 0;
	}
	else
	{
var flag=true;
flag=consecutiveSpecialChar(textval.trim());

if(flag)
{
	Names.value=textval.trim();
}
else
{
	
	  bootbox.alert("Consecutive blank spaces are not allowed for "+arg2,function(){
		  focusBox(document.getElementById(arg));
	        textbox1.value="";
	  });
	  parent.parent.$('html, body').animate({scrollTop: 0}, 500, 'linear');
	
	return false;
}
}
}
var ValidChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz.(),";
var IsNumber=true;
var Char; 
Names.value=textval.trim();
if(textval.length > 0)
{
  for (i = 0; i < textval.length && IsNumber == true; i++) 
	 { 
        Char = textval.charAt(i); 
       if (ValidChars.indexOf(Char) == -1) 
		{  
    	  
  		 bootbox.alert("Only Characters from A-Z,a-z are allowed in "+arg2, function() {
  	      
  	        focusBox(document.getElementById(arg));
  	      textbox1.value="";
  		  });
    	   parent.parent.$('html, body').animate({scrollTop: 0}, 500, 'linear');
    	  

			return false;
		 }
  		 
		}
  
if( textval.match(/[,.\(\)\/]{2}/i))
	{
	var fr = partial(textbox1);
	  
	 bootbox.alert("Continuous special characters are not allowed in "+arg2, function() {
	      
	        focusBox(document.getElementById(arg));
	       textbox1.value="";
		  });
	   parent.parent.$('html, body').animate({scrollTop: 0}, 500, 'linear');
	}
 var iChars = "~`!#$%^&*+=-[]\\\';,/{}|\":<>?.";
    if(iChars.indexOf(textval.charAt(0))!= -1){
    	
		 bootbox.alert('Starting special characters are not allowed in '+arg2, function() {
	   	      
	 	        focusBox(document.getElementById(arg));
	 	       textbox1.value="";
	 		  });
	   	   parent.parent.$('html, body').animate({scrollTop: 0}, 500, 'linear');
    }
    

}
else 
	return false;
}

$('[data-toggle="tooltip"]').tooltip(); 
