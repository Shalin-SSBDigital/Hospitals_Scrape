function viewPreviousPages(pageNo,noOfPages,selectedPage)
{
	var pageDisplays='';
	var pageNoLim=pageNo;
	var minPageNo=pageNo-10;
	var action='link';
	var i=0;
	if(minPageNo>0)
	{
		pageDisplays=pageDisplays+'<a href="javascript:viewPreviousPages('+minPageNo+','+noOfPages+','+selectedPage+')">Previous</a>&nbsp;&nbsp;';
	}
	else
	{
		minPageNo=minPageNo+1;
	}
	for(i=minPageNo;i<pageNoLim;i++)
	{
		if(selectedPage==i)
		{
			pageDisplays=pageDisplays+''+i+'&nbsp;';
		}
		else
		{
			pageDisplays=pageDisplays+'<a href="javascript:fn_pagination('+i+',\''+action+'\')">'+i+'</a>&nbsp;&nbsp;';
		}
		
	}
	pageDisplays=pageDisplays+'<a href="javascript:viewNextPages('+i+','+noOfPages+','+selectedPage+')">Next</a>';
	document.getElementById("pageNoDisplay").innerHTML=pageDisplays;
}

function viewNextPages(pageNo,noOfPages,selectedPage)
{
	var pageDisplays='';
	var pageNoLim=pageNo+10;
	var action='link';
	var i=0;
	if(pageNoLim>noOfPages)
	{
		pageNoLim=noOfPages+1;
	}
	pageDisplays=pageDisplays+'<a href="javascript:viewPreviousPages('+pageNo+','+noOfPages+','+selectedPage+')">Previous</a>&nbsp;&nbsp;';
	for(i=pageNo;i<pageNoLim;i++)
	{
		if(selectedPage==i)
		{
			pageDisplays=pageDisplays+''+i+'&nbsp;';
		}
		else
		{
			pageDisplays=pageDisplays+'<a href="javascript:fn_pagination('+i+',\''+action+'\')">'+i+'</a>&nbsp;&nbsp;';
		}
		
	}
	if(i<noOfPages)
	{
		pageDisplays=pageDisplays+'<a href="javascript:viewNextPages('+i+','+noOfPages+','+selectedPage+')">Next</a>';
	}
	document.getElementById("pageNoDisplay").innerHTML=pageDisplays;
}




function getHospitalNamesList()
{

	//alert("hospname fn");
	 $('#searchHospName').select2('val','-1');
	 
	 var specSearch = null;
	var xmlhttp;
	var url;
	var stateId = $('#searchState').val();
	var distCode = $('#searchDistrict').val();
	var hospType = $('#searchHospType').val();
	var hospSpec = $('#searchSpeciality').val();
	var hospName = $('#searchHospName').val();
	var empanelmentType =  $('#empanelmentType').val();
	
	//alert("distCode"+distCode+"hospType"+hospType+"hospSpec"+hospSpec+"hospName"+hospName);
	if(hospSpec != null && hospSpec != "-1"){
		specSearch = 'Y';
	}else{
		specSearch = 'N';
	}
	if (window.XMLHttpRequest) {
		xmlhttp = new XMLHttpRequest();
	} else if (window.ActiveXObject) {
		xmlhttp = new ActiveXObject("Microsoft.XMLHTTP");
	} else {
		alert("Your browser does not support XMLHTTP!");
	}
	xmlhttp.onreadystatechange = function() {
		if (xmlhttp.readyState == 4) {
			var resultArray = xmlhttp.responseText;
			resultArray = resultArray.replace("*", "");
			resultArray = resultArray.replace("[", "");
			resultArray = resultArray.replace("]", "");
			var hospNamesList = resultArray.split(",");

			if (hospNamesList.length > 0) {

				
				document.forms[0].searchHospName.options.length=0;
              document.forms[0].searchHospName.options[0]=new Option("---select---","");
				for (var i = 0; i < hospNamesList.length; i++) {

					var arr = hospNamesList[i].split("~");
					if (arr[1] != null && arr[0] != null) {
						var val1 = arr[1].replace(/^\s+|\s+$/g, "");
						var val2 = arr[0].replace(/^\s+|\s+$/g, "");

						document.forms[0].searchHospName.options[i + 1] = new Option(
								val1, val2);

					} 

				}
				
				if(hospVal != null && hospVal != '-1' && hospVal != 'NA'){
					//alert("in"+distVal);
					$("#searchHospName").select2('val',hospVal);
				}
			
			}

		}
	}
	url = "empanelApplicationForm.htm?actionVal=GETHOSPNAMESLIST&stateId="+stateId+"&empanelmentType="+empanelmentType+"&distCode="+distCode+"&hospType="
			+hospType+"&hospSpec="+hospSpec+"&hospName="+hospName+"&specSearch="+specSearch;
	xmlhttp.open("Post", url, true);
	xmlhttp.send(null);

}

function getDistrictList() {
	//alert("districts onchange");
	 $('#searchDistrict').select2('val','-1');
	var xmlhttp;
	var url;

	var stateCode = $('#searchState').val();
	if (window.XMLHttpRequest) {
		xmlhttp = new XMLHttpRequest();
	} else if (window.ActiveXObject) {
		xmlhttp = new ActiveXObject("Microsoft.XMLHTTP");
	} else {
		alert("Your browser does not support XMLHTTP!");
	}
	xmlhttp.onreadystatechange = function() {
		if (xmlhttp.readyState == 4) {
			var resultArray = xmlhttp.responseText;
			resultArray = resultArray.replace("*", "");
			resultArray = resultArray.replace("[", "");
			resultArray = resultArray.replace("]", "");
			var districtList = resultArray.split(",");

			if (districtList.length > 0) {

				
				document.forms[0].searchDistrict.options.length=0;
               document.forms[0].searchDistrict.options[0]=new Option("---select---","-1");
				for (var i = 0; i < districtList.length; i++) {

					var arr = districtList[i].split("~");
					if (arr[1] != null && arr[0] != null) {
						var val1 = arr[1].replace(/^\s+|\s+$/g, "");
						var val2 = arr[0].replace(/^\s+|\s+$/g, "");

						document.forms[0].searchDistrict.options[i + 1] = new Option(
								val1, val2);

					} else {
						/* $('#district').empty();
						$("#district").append('<option value="NA">------Select-----</option>'); */
					}

				}
				
				if(distVal != null && distVal != '-1' && distVal != 'NA'){
					//alert("in"+distVal);
					$("#searchDistrict").select2('val',distVal);
				}
			
			}

		}
	}
	url = "empanelApplicationForm.htm?actionVal=GETLOCATIONS&locType=DT&locVal="+stateCode;
	var districtCode = $('#district').val();
	xmlhttp.open("Post", url, true);
	xmlhttp.send(null);
}


function stateSelected()
{
	var state=null;
	var lStrHdrId='LH6';
	state=document.getElementById("searchState").value;
	var xmlhttp;
    var url;

    if (window.XMLHttpRequest)
    {
     xmlhttp=new XMLHttpRequest();
    }
    else if (window.ActiveXObject)
    {		
     xmlhttp=new ActiveXObject("Microsoft.XMLHTTP");
    }
    else
    {
    	jqueryInfoMsg('Ajax XMLHTTP Support',"Your browser does not support XMLHTTP!");
    }
  
    xmlhttp.onreadystatechange=function()
    {
        if(xmlhttp.readyState==4)
        {
            var resultArray=xmlhttp.responseText;
            if(resultArray.trim()=="SessionExpired*"){
            	parent.sessionExpireyClose;
            }
            else
            {
            	if(resultArray!=null)
            	{
            		resultArray = resultArray.replace("[","");
            		resultArray = resultArray.replace("]*","");            
            		var districtList = resultArray.split(","); 
            		if(districtList.length>0)
            		{  
            			document.forms[0].searchDistrict.options.length=0;
            			document.forms[0].searchDistrict.options[0]=new Option("---select---","-1");
            			for(var i = 0; i<districtList.length;i++)
            			{	
            				var arr=districtList[i].split("~");
            				if(arr[1]!=null && arr[0]!=null)
            				{
            					var val1 = arr[1].replace(/^\s+|\s+$/g,"");
            					var val2 = arr[0].replace(/^\s+|\s+$/g,"");
            					document.forms[0].searchDistrict.options[i+1] =new Option(val1,val2);
            				}
            			}
            		}
            	}
            }
        }
    }
	url = "empnlWorkFlow.htm?actionFlag=getLocations&callType=Ajax&lStrHdrId="+lStrHdrId+"&stateId="+state;
	xmlhttp.open("Post",url,true);
	xmlhttp.send(null);
}

