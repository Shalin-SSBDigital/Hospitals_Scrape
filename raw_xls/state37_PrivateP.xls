  <script>
  function redirectToHome()
  {
	  fn_load_image();
	  location.href="https://mera.pmjay.gov.in/search/login";
  }
  
  var imgCrtCount=1;
	function fn_refreshCaptcha()
	{
		document.getElementById('imgCreateAct').src = "empanelApplicationForm.htm?actionVal=changeimageCreateAcnt&change="+imgCrtCount;
		imgCrtCount = imgCrtCount+1;
			
			
		}
	

	function fn_ValidateCaptcha() {

		//check for user name and password
		var state=document.getElementById("searchState").value;
		var district=document.getElementById("searchDistrict").value;
		var hospType=document.getElementById("searchHospType").value;
		var specialityType=document.getElementById("searchSpeciality").value;
		var hospName=document.getElementById("searchHospName").value;
		var empType=document.getElementById("empanelmentType").value;
	
		if((state=='' || state == null || state=='-1') && (district=='' || district == null|| district=='-1') && (hospType=='' || hospType == null || hospType=='-1') && (specialityType=='' || specialityType == null || specialityType=='-1') && (hospName=='' || hospName == null) && (empType=='' || empType == null || empType == '-1'))
			{
			bootbox.alert("Please select any search criteria",function(){			 	  
			 	  });

	        return false;
			}		
		var cap = $('#j_captcha_response_crtacnt').val();
		if(cap=='' || cap == null)
	    {
			bootbox.alert("Please Enter Captcha Code",function(){
				focusBox(document.getElementById("j_captcha_response_crtacnt"));	
		    });
	        return false;
	    } 
		
		var xmlhttp;
		var url;
		if (window.XMLHttpRequest) {
			xmlhttp = new XMLHttpRequest();
		} else if (window.ActiveXObject) {
			xmlhttp = new ActiveXObject("Microsoft.XMLHTTP");
		} else {
			alert("Your browser does not support XMLHTTP!");
		}

		xmlhttp.onreadystatechange = function() {
			if (xmlhttp.readyState == 4) {
				 var resultArray=xmlhttp.responseText.split("*");
				  var msg =resultArray[0];
				 // alert(msg);
		   		  if(msg=="FAILURE")
		   			  {
		   				$("#errormsgCrtAcnt").show();
		   				$('#j_captcha_response_crtacnt').val('');
		   			  
		   			  }
		   		  else
		   			  {
		   			  $("#errormsgCrtAcnt").hide();
		   			fnSearch();
		   			  }
       }
		}
		var cap = $('#j_captcha_response_crtacnt').val();
		 url = "empanelApplicationForm.htm";
			
			xmlhttp.open("Post", url, true);
			xmlhttp.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
			xmlhttp.send("actionVal=captchapageCrtAcnt&j_captcha_response="+cap);
	}

	function focusBoxCaptcha(arg)
	{	
		
		lField = arg; 
		setTimeout("lField.focus()", 0); 
		
	}
  
  </script>
