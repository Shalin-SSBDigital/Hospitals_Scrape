		var search='Y';var applSearch='';var appReadOnly = 'Y';var draftMenu = '';var isRSBY ='';var invalidMenu = '';//alert(isRSBY);
		   document.forms[0].action='empnlWorkFlow.htm?actionFlag=ViewIndividualHosptlDtls&search='+search+'&applSearch='+applSearch+'&hospInfoId='+id+'&appReadOnly='
				   +appReadOnly+'&draftMenu='+draftMenu+'&isRSBY='+isRSBY
				   +'&invalidMenu='+invalidMenu;
		   
		   //alert(document.forms[0].action);
		   document.forms[0].method="post";
		   document.forms[0].submit();  
		   fn_load_image();
	}
	
